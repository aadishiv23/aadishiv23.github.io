---
// src/layouts/Layout.astro
const { title = 'Aadi Shiv Malhotra', description = 'Aadi Shiv Malhotra — software engineer and builder.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" /> {/* Ensure proper viewport */}
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e9efff" />
    <link rel="icon" type="image/png" href="/images/icons/ASM.png" />
    <title>{title}</title>
    {/* Ensure Tailwind (or your CSS) is loaded globally, typically via astro.config.mjs or a global CSS import */}
    <style is:global>
      /* Basic body styling to prevent default margins/padding */
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; padding: 0; min-height: 100%; }
      button, a { font: inherit; }
      a { color: inherit; text-decoration: none; }
      html.dark {
        color-scheme: dark;
      }
       /* Optional: Basic scrollbar styling for windows */
       ::-webkit-scrollbar { width: 8px; height: 8px; }
       ::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); border-radius: 4px; }
       ::-webkit-scrollbar-thumb { background-color: rgba(0,0,0,0.3); border-radius: 4px; }
       html.dark ::-webkit-scrollbar-track { background: rgba(255,255,255,0.1); }
       html.dark ::-webkit-scrollbar-thumb { background-color: rgba(255,255,255,0.3); }
       ::-webkit-scrollbar-thumb:hover { background-color: rgba(0,0,0,0.5); }
       html.dark ::-webkit-scrollbar-thumb:hover { background-color: rgba(255,255,255,0.5); }
    </style>
  </head>
  <body>
    <main id="main"><slot /></main>
  </body>
</html>
